# =============================================================================
# wondr Intelligence Engine — Root .gitignore
# Security-hardened: no private data, credentials, or test artifacts may leak.
# =============================================================================

# ── Node.js / Next.js ─────────────────────────────────────────────────────────
node_modules/
.next/
out/
build/
.pnp
.pnp.js
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo
next-env.d.ts

# ── Python / FastAPI ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.venv/
venv/
env/
ENV/
wondr-env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Databases ─────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
wondr_local.db

# ── Environment variables & secrets ──────────────────────────────────────────
.env
.env.*
.env.local
.env.production
.env.test
*.env
.envrc
secrets/
credentials/
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
service-account*.json
*-credentials.json
*-secret*.json

# ── FINANCIAL / PERSONAL TEST ARTIFACTS — HARD BLOCK ─────────────────────────
# Bank statement PDFs
MutasiBCA*.pdf
MutasiBRI*.pdf
MutasiMandiri*.pdf
MutasiBNI*.pdf
*.pdf

# Portfolio screenshots (Ajaib, Bibit, Stockbit, etc.)
image_*.jpg
image_*.jpeg
image_*.png
Ajaib*.jpg
Ajaib*.jpeg
Ajaib*.png
Bibit*.png
Stockbit*.png
screenshot*.png
screenshot*.jpg
Screenshot*.png
Screenshot*.jpg

# Blanket block on all image types everywhere in the repo...
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.webp
*.tiff
*.tif
*.ico
*.svg

# ...except intentional frontend UI assets
!apps/frontend/public/
!apps/frontend/public/**
!apps/frontend/app/favicon.ico

# ── IDE & OS artifacts ────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Misc build / cache artifacts ──────────────────────────────────────────────
coverage/
dist/
*.log
.cache/
tmp/
temp/
